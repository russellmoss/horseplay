# derby-edge configuration
# Copy this file to .env (gitignored) and edit values as needed.
# DO NOT put FanDuel passwords or any credentials here.
# Authentication is handled by Playwright via auth/storageState.json,
# which is created by `pnpm run login` and is also gitignored.

# --- Database (Neon) -------------------------------------------------------
# Used for persisting race analyses so the Vercel-hosted viewer can read them.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Scraper ----------------------------------------------------------------
# Set to "true" on the local machine that runs the Playwright scraper.
# On Vercel (viewer-only), leave unset.
ENABLE_SCRAPER=true

# --- Tracks ----------------------------------------------------------------
# Fallback track codes when DATABASE_URL is not set or DB is unreachable.
# When the DB is available, tracks are managed via the dashboard UI and
# stored in the tracked_tracks table.
TRACKED_TRACKS=CD

# --- FanDuel Racing endpoints ----------------------------------------------
# Base URL — should rarely need to change.
FDR_BASE_URL=https://racing.fanduel.com

# --- Polling cadences (in seconds) -----------------------------------------
# Aggressive cadence within 10 minutes of post.
POLL_CADENCE_LIVE_SECONDS=15

# Mid cadence: 10–60 min from post.
POLL_CADENCE_NEAR_SECONDS=60

# Far cadence: more than 60 min from post.
POLL_CADENCE_FAR_SECONDS=300

# Max simultaneous in-flight scraper requests.
POLL_CONCURRENCY=3

# --- Takeout assumptions ---------------------------------------------------
# Default US pari-mutuel takeouts. Override per track if you know the actual
# rates differ. Used in projected Place/Show payout math.
TAKEOUT_PLACE=0.17
TAKEOUT_SHOW=0.17

# --- Signal thresholds -----------------------------------------------------
# Mid-edge threshold for the "lean" signal (0.05 = 5% positive edge).
SIGNAL_LEAN_THRESHOLD=0.05

# ML drift threshold for the "drift" signal (0.5 = horse went off at 1.5x ML).
SIGNAL_DRIFT_THRESHOLD=0.5

# --- Logging --------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info

# --- Dashboard ------------------------------------------------------------
# How often the client polls /api/odds (in milliseconds).
DASHBOARD_POLL_MS=5000

# Sound alert on new slam-dunk signals.
ENABLE_SOUND_ALERTS=true

# --- Council of Models MCP -------------------------------------------------
# Used by .claude/commands/council.md for adversarial cross-LLM review.
# council-mcp reads this file via dotenv when started from the project root.
# Codex CLI uses its own auth (`codex login`) — no API key needed for ask_codex.
GEMINI_API_KEY=

# --- Anthropic API key -----------------------------------------------------
# Available for future agents / SDK calls. Not required by council-mcp.
ANTHROPIC_API_KEY=

# --- Tavily web search (used by the chat-with-the-bookmaker feature) -------
# Get a key at https://tavily.com (free tier ~1000 searches / month).
TAVILY_API_KEY=
